# Sub2API 实例地址（本地部署默认 http://localhost:8080）
SUB2API_BASE_URL=http://localhost:8080

# 在 Sub2API 后台 /admin/settings 生成的 Admin API Key
# 该 Key 通过 x-api-key header 走 admin 路由（参见 sub2api/backend/internal/server/middleware/admin_auth.go）
SUB2API_ADMIN_API_KEY=

# 可选：新建账号默认进入哪些分组（逗号分隔的 group ID）
SUB2API_DEFAULT_GROUP_IDS=
